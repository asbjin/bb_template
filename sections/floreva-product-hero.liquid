{{ 'floreva-product-hero.css' | asset_url | stylesheet_tag }}

{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="floreva-hero" id="floreva-product-hero">
  <div class="floreva-hero__grid">

    <!-- ============================
         GALLERY (Left)
         ============================ -->
    <div class="floreva-gallery">
      <div class="floreva-gallery__main" id="floreva-main-gallery">
        {%- for media in product.media -%}
          <div class="floreva-gallery__main-slide{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
            {%- if media.media_type == 'image' -%}
              <img
                src="{{ media | image_url: width: 900 }}"
                alt="{{ media.alt | escape }}"
                width="{{ media.width }}"
                height="{{ media.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
              {{ media | media_tag: autoplay: false, controls: true }}
            {%- endif -%}
          </div>
        {%- endfor -%}

        <button class="floreva-gallery__nav floreva-gallery__nav--prev" aria-label="Image précédente" onclick="florevaGallery.prev()">
          &#8249;
        </button>
        <button class="floreva-gallery__nav floreva-gallery__nav--next" aria-label="Image suivante" onclick="florevaGallery.next()">
          &#8250;
        </button>
      </div>

      <div class="floreva-gallery__thumbs" id="floreva-thumbs">
        {%- for media in product.media -%}
          {%- if media.media_type == 'image' -%}
            <div
              class="floreva-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              onclick="florevaGallery.goTo({{ forloop.index0 }})"
            >
              <img
                src="{{ media | image_url: width: 160 }}"
                alt="{{ media.alt | escape }}"
                loading="lazy"
                width="72"
                height="72"
              >
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="floreva-gallery__counter">
        <span id="floreva-gallery-current">1</span> / {{ product.media.size }}
      </div>
    </div>

    <!-- ============================
         PRODUCT INFO (Right)
         ============================ -->
    <div class="floreva-info">

      <!-- Mini Testimonials Slider -->
      {%- if section.blocks.size > 0 -%}
        {%- assign testimonial_blocks = section.blocks | where: "type", "testimonial" -%}
        {%- if testimonial_blocks.size > 0 -%}
          <div class="floreva-testimonials-mini" id="floreva-mini-testimonials">
            {%- for block in testimonial_blocks -%}
              <div class="floreva-testimonials-mini__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                <div class="floreva-testimonials-mini__text">
                  "{{ block.settings.text }}"
                </div>
                <div class="floreva-testimonials-mini__bottom">
                  <span class="floreva-testimonials-mini__stars">★★★★★</span>
                  <span class="floreva-testimonials-mini__author">{{ block.settings.author }}</span>
                </div>
              </div>
            {%- endfor -%}

            {%- if testimonial_blocks.size > 1 -%}
              <div class="floreva-testimonials-mini__dots">
                {%- for block in testimonial_blocks -%}
                  <button
                    class="floreva-testimonials-mini__dot{% if forloop.first %} is-active{% endif %}"
                    data-index="{{ forloop.index0 }}"
                    onclick="florevaTestimonials.goTo({{ forloop.index0 }})"
                    aria-label="Témoignage {{ forloop.index }}"
                  ></button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      <!-- Rating -->
      <div class="floreva-rating">
        <span class="floreva-rating__stars">★★★★★</span>
        <span class="floreva-rating__count">{{ section.settings.review_count }} Avis</span>
      </div>

      <!-- Title -->
      <h1 class="floreva-info__title">{{ section.settings.product_title | default: product.title }}</h1>

      <!-- Description -->
      <div class="floreva-info__description">
        {{ section.settings.product_description }}
      </div>

      <!-- Benefits -->
      <ul class="floreva-benefits">
        {%- for i in (1..6) -%}
          {%- assign benefit_key = 'benefit_' | append: i -%}
          {%- if section.settings[benefit_key] != blank -%}
            <li class="floreva-benefits__item">
              <span class="floreva-benefits__icon">✓</span>
              <span>{{ section.settings[benefit_key] }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <!-- Supplement Mini Facts -->
      {%- if section.settings.show_supplement_facts -%}
        <div class="floreva-supplement">
          <div class="floreva-supplement__title">{{ section.settings.supplement_title | default: 'Composition par dose (2 capsules)' }}</div>
          {%- for i in (1..4) -%}
            {%- assign ingredient_key = 'ingredient_' | append: i -%}
            {%- assign dose_key = 'dose_' | append: i -%}
            {%- if section.settings[ingredient_key] != blank -%}
              <div class="floreva-supplement__row">
                <span>{{ section.settings[ingredient_key] }}</span>
                <span class="floreva-supplement__dose">{{ section.settings[dose_key] }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <!-- Price -->
      <div class="floreva-price">
        <span class="floreva-price__current">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="floreva-price__compare">{{ current_variant.compare_at_price | money }}</span>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
          <span class="floreva-price__badge">-{{ savings }}%</span>
        {%- endif -%}
      </div>

      <!-- Add to Cart -->
      {%- form 'product', product, id: 'floreva-product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- if product.variants.size > 1 -%}
          <select name="id" id="floreva-variant-select" style="width:100%;padding:12px;border:1px solid var(--floreva-border);border-radius:var(--floreva-radius);margin-bottom:12px;font-size:14px;background:#fff;">
            {%- for variant in product.variants -%}
              <option
                value="{{ variant.id }}"
                {% if variant == current_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
                data-price="{{ variant.price | money }}"
                data-compare-price="{{ variant.compare_at_price | money }}"
              >
                {{ variant.title }} — {{ variant.price | money }}
                {%- unless variant.available %} (Épuisé){% endunless -%}
              </option>
            {%- endfor -%}
          </select>
        {%- endif -%}

        <button
          type="submit"
          class="floreva-atc"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}
            {{ section.settings.atc_text | default: 'Ajouter au panier' }}
          {%- else -%}
            Épuisé
          {%- endif -%}
        </button>
      {%- endform -%}

      <span class="floreva-atc__subtext">{{ section.settings.atc_subtext | default: '🔒 Paiement 100% sécurisé · Livraison offerte' }}</span>

      <!-- Trust Badges -->
      <div class="floreva-trust">
        {%- for i in (1..3) -%}
          {%- assign badge_icon_key = 'badge_icon_' | append: i -%}
          {%- assign badge_label_key = 'badge_label_' | append: i -%}
          {%- assign badge_sublabel_key = 'badge_sublabel_' | append: i -%}
          {%- if section.settings[badge_label_key] != blank -%}
            <div class="floreva-trust__item">
              {%- if section.settings[badge_icon_key] != blank -%}
                <img class="floreva-trust__icon" src="{{ section.settings[badge_icon_key] | image_url: width: 80 }}" alt="{{ section.settings[badge_label_key] }}" loading="lazy" width="40" height="40">
              {%- else -%}
                <div class="floreva-trust__icon-placeholder">
                  {%- case i -%}
                    {%- when 1 -%}⚡
                    {%- when 2 -%}🛡️
                    {%- when 3 -%}🚚
                  {%- endcase -%}
                </div>
              {%- endif -%}
              <span class="floreva-trust__label">{{ section.settings[badge_label_key] }}</span>
              {%- if section.settings[badge_sublabel_key] != blank -%}
                <span class="floreva-trust__sublabel">{{ section.settings[badge_sublabel_key] }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<!-- ============================
     JavaScript
     ============================ -->
<script>
  // Gallery
  const florevaGallery = {
    current: 0,
    total: {{ product.media.size }},
    slides: null,
    thumbs: null,
    counter: null,

    init() {
      this.slides = document.querySelectorAll('.floreva-gallery__main-slide');
      this.thumbs = document.querySelectorAll('.floreva-gallery__thumb');
      this.counter = document.getElementById('floreva-gallery-current');
      if (this.total <= 1) {
        document.querySelectorAll('.floreva-gallery__nav').forEach(n => n.style.display = 'none');
      }
      // Swipe support
      let startX = 0;
      const main = document.getElementById('floreva-main-gallery');
      if (main) {
        main.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
        main.addEventListener('touchend', (e) => {
          const diff = startX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) { diff > 0 ? this.next() : this.prev(); }
        }, { passive: true });
      }
    },

    goTo(index) {
      this.slides.forEach(s => s.classList.remove('is-active'));
      this.thumbs.forEach(t => t.classList.remove('is-active'));
      this.current = index;
      if (this.slides[index]) this.slides[index].classList.add('is-active');
      if (this.thumbs[index]) {
        this.thumbs[index].classList.add('is-active');
        this.thumbs[index].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
      if (this.counter) this.counter.textContent = index + 1;
    },

    next() { this.goTo((this.current + 1) % this.total); },
    prev() { this.goTo((this.current - 1 + this.total) % this.total); }
  };

  // Testimonials Mini Slider
  const florevaTestimonials = {
    current: 0,
    slides: null,
    dots: null,
    total: 0,
    interval: null,

    init() {
      this.slides = document.querySelectorAll('.floreva-testimonials-mini__slide');
      this.dots = document.querySelectorAll('.floreva-testimonials-mini__dot');
      this.total = this.slides.length;
      if (this.total > 1) {
        this.interval = setInterval(() => this.next(), 5000);
      }
    },

    goTo(index) {
      this.slides.forEach(s => s.classList.remove('is-active'));
      this.dots.forEach(d => d.classList.remove('is-active'));
      this.current = index;
      if (this.slides[index]) this.slides[index].classList.add('is-active');
      if (this.dots[index]) this.dots[index].classList.add('is-active');
      // Reset auto-advance
      if (this.interval) clearInterval(this.interval);
      this.interval = setInterval(() => this.next(), 5000);
    },

    next() { this.goTo((this.current + 1) % this.total); }
  };

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    florevaGallery.init();
    florevaTestimonials.init();
  });
</script>

